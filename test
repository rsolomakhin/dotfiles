set -e

FAILED=0

echo "[Test] Verifying no absolute paths..."
if ! python3 scripts/check_no_absolute_paths.py; then
  FAILED=1
fi

# Setup a sandbox directory for testing.
TEST_HOME="/tmp/test_sandbox"
rm -rf "$TEST_HOME"
mkdir -p "$TEST_HOME"

echo "[Test] Installing dotfiles into $TEST_HOME..."
# Run the installation script with HOME overridden.
HOME="$TEST_HOME" ./install --name "Test User" --email "test@example.com"

echo "[Test] Verifying installation..."

# Files that should be symlinked from src/.
EXPECTED_SYMLINKS=(
  ".bash_profile"
  ".bashrc"
  ".common.sh"
  ".cvsignore"
  ".darwin.sh"
  ".emacs"
  ".eslintrc"
  ".gitconfig"
  ".linux.sh"
  ".profile"
  ".tmux.conf"
  ".vimrc"
  ".Xresources"
  ".zshrc"
  ".vim/coc.vim"
)

# Files that are downloaded or created during installation.
EXPECTED_FILES=(
  ".vim/autoload/plug.vim"
  ".gitconfig.user"
)

for file in "${EXPECTED_SYMLINKS[@]}"; do
  if [ ! -L "$TEST_HOME/$file" ]; then
    echo "[Error] Missing or not a symlink: $TEST_HOME/$file"
    FAILED=1
  fi
done

for file in "${EXPECTED_FILES[@]}"; do
  if [ ! -f "$TEST_HOME/$file" ]; then
    echo "[Error] Missing file: $TEST_HOME/$file"
    FAILED=1
  fi
done

echo "[Test] Verifying Vim configuration..."
# Run vim in silent Ex mode (-es) to avoid interactive prompts.
# -u ensures we use the sandboxed config.
# --cmd ensures the runtimepath is correct before the config is loaded.
HOME="$TEST_HOME" vim -u "$TEST_HOME/.vimrc" --cmd "set rtp+=$TEST_HOME/.vim" -es -c "redir! > $TEST_HOME/vim_messages | messages | qall!"

if grep -qi "error" "$TEST_HOME/vim_messages"; then
  echo "[Error] Vim reported errors during startup:"
  cat "$TEST_HOME/vim_messages"
  FAILED=1
fi

echo "[Test] Verifying Vim warning for missing coc.vim..."
# Intentionally remove coc.vim and check for the warning.
rm "$TEST_HOME/.vim/coc.vim"
HOME="$TEST_HOME" vim -u "$TEST_HOME/.vimrc" --cmd "set rtp+=$TEST_HOME/.vim" -es -c "redir! > $TEST_HOME/vim_warning | messages | qall!"
if ! grep -q "Warning: ~/.vim/coc.vim not found" "$TEST_HOME/vim_warning"; then
  echo "[Error] Vim failed to warn about missing coc.vim"
  FAILED=1
fi

if [ $FAILED -eq 0 ]; then
  echo "[Test] Success!"
else
  echo "[Test] Failed!"
  exit 1
fi
