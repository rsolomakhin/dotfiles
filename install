# Get the directory where this script is located
REPO_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

LINKER="ln --symbolic --force --verbose --no-target-directory"
if [ "`uname`" = "Darwin" ]; then
  LINKER="ln -f -s -v"
fi

# Parse arguments for Git identity
while [[ $# -gt 0 ]]; do
  case $1 in
    --name)
      GIT_NAME="$2"
      shift 2
      ;;
    --email)
      GIT_EMAIL="$2"
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

if [ ! -f ~/.gitconfig.user ]; then
  if [ -z "$GIT_NAME" ]; then
    read -p "Enter your Git name: " GIT_NAME
  fi
  if [ -z "$GIT_EMAIL" ]; then
    read -p "Enter your Git email: " GIT_EMAIL
  fi

  if [ -n "$GIT_NAME" ] && [ -n "$GIT_EMAIL" ]; then
    echo "[user]" > ~/.gitconfig.user
    echo "	name = $GIT_NAME" >> ~/.gitconfig.user
    echo "	email = $GIT_EMAIL" >> ~/.gitconfig.user
    echo "Created ~/.gitconfig.user with your identity."
  fi
fi

for src_file in `git ls-files src/`; do
  file=`echo $src_file | sed 's|^src/||'`
  dest=~/.$file

  mkdir -pv ~/.`dirname $file`

  if [ -f "$dest" ] && [ ! -L "$dest" ]; then
    echo "Backing up $dest to $dest.bak"
    mv "$dest" "$dest.bak"
  fi

  $LINKER "$REPO_DIR/$src_file" "$dest"
done

PLUG_VIM=~/.vim/autoload/plug.vim
# Only download if missing, older than 24h, or corrupted (truncated).
if [ ! -f "$PLUG_VIM" ] || [ -n "$(find "$PLUG_VIM" -mmin +1440)" ] || ! grep -q "unlet s:cpo_save" "$PLUG_VIM"; then
  mkdir -pv ~/.vim/autoload
  curl -fLo "$PLUG_VIM.tmp" \
      https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim && \
      mv "$PLUG_VIM.tmp" "$PLUG_VIM"
fi
